---
const currentPath = Astro.url.pathname;
const isProjects = currentPath === "/projects" || currentPath === "/projects/";
const isBlogs = currentPath === "/blogs" || currentPath === "/blogs/";
---

<nav class="flex items-center justify-between pb-5 mb-8 border-b border-border">
    <a href="/" class="font-serif italic text-2xl text-charcoal">
        Arun Prajapati
    </a>
    <div class="flex items-center gap-1">
        <!-- <a
            href="/projects"
            class:list={[
                "text-sm font-medium px-3.5 py-1.5 rounded-full transition-all duration-150",
                isProjects
                    ? "text-charcoal bg-pill-bg border border-border"
                    : "text-muted hover:text-charcoal hover:bg-pill-bg",
            ]}
        >
            Projects
        </a> -->
        <a
            href="/blogs"
            class:list={[
                "text-sm font-medium px-3.5 py-1.5 rounded-full transition-all duration-150",
                isBlogs ? "text-charcoal" : "text-muted hover:text-charcoal ",
            ]}
        >
            Blogs
        </a>
    </div>
</nav>
